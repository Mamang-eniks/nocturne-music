  "author": "Nikss",
  "license": "MIT",
  "dependencies": {
    "@discord-player/extractor": "^4.5.1",
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "discord-player": "^6.7.1",
    "discord-player-youtubei": "^1.5.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "mediaplex": "^0.0.9",
    "mongoose": "^8.7.2",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "yt-search": "^2.11.1",
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
