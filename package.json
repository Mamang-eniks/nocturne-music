{
  "name": "nocturne-music-bot",
  "version": "1.0.0",
  "description": "Nocturne \u2014 a premium, production-ready Discord music bot built with discord.js v14 and discord-player.",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy": "node src/deploy-commands.js",
    "lint": "eslint .",
    "postinstall": "patch-package"
  },
  "keywords": [
    "discord",
    "music-bot",
