# ─── Nocturne — Environment Variables ───────────────────────────────
# Copy this file to ".env" for local development.
# On Railway, set these under Project → Variables.

# Discord Bot Credentials
TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
GUILD_ID=your_dev_guild_id_for_fast_slash_command_sync

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/nocturne

# Command Prefix (fallback if not set per-guild in DB)
PREFIX=!

# Comma separated list of owner user IDs (no-prefix + eval access)
OWNER_ID=123456789012345678,987654321098765432

# Optional — default music-only text channel (per-guild override lives in DB)
MUSIC_CHANNEL_ID=

# Optional — Genius API token, enables the /lyrics command
GENIUS_API_KEY=

# Node environment
NODE_ENV=production
