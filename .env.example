# ─────────────────────────────────────────────
#  NOCTURNE — Environment Variables Template
#  Copy this file to ".env" for local development.
#  On Railway, set these under Project → Variables.
# ─────────────────────────────────────────────

# Discord bot token (Developer Portal → Bot → Token)
TOKEN=

# Discord application/client ID (Developer Portal → General Information)
CLIENT_ID=

# Guild ID used for instant (guild-scoped) slash command registration during development.
# Leave empty in production to register commands globally.
GUILD_ID=

# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGO_URI=

# Default prefix for prefix commands (can be overridden per-guild via !setprefix)
PREFIX=!n

# Comma-separated list of Discord user IDs allowed to use owner-only and no-prefix commands
OWNER_ID=

# Optional: restrict the music panel / no-prefix commands to a specific channel
MUSIC_CHANNEL_ID=

# Node environment: "development" | "production"
NODE_ENV=production
